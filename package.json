    "test": "jest",
    "test:unit": "jest --no-coverage --testPathIgnorePatterns=\"integration|nodeInteraction|test.test|proto-serialize\"",
    "bulletproof": "npm run format && npm run lint:fix && npm run typecheck && npm run test:unit",
    "bulletproof:check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit",
    "prepare": "husky"
